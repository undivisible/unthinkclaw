# unthinkclaw — required environment variables
# Copy this to .env and fill in your values

# AI provider API key (at least one required)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# Gateway configuration
# UNTHINKCLAW_GATEWAY_TOKEN=

# Web dashboard (optional, for web/ Next.js app)
# NEXT_PUBLIC_GATEWAY_URL=http://127.0.0.1:8080
# NEXT_PUBLIC_GATEWAY_WS_URL=ws://127.0.0.1:8080
# NEXT_PUBLIC_GATEWAY_TOKEN=

# Telegram channel (optional)
# TELEGRAM_BOT_TOKEN=

# Discord channel (optional)
# DISCORD_BOT_TOKEN=

# Web search (optional)
# PERPLEXITY_API_KEY=
# BRAVE_SEARCH_API_KEY=
